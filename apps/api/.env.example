# Copy this file to .env and fill in the values.
# cp apps/api/.env.example apps/api/.env

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# -----------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/promanage_dev?schema=public"

# -----------------------------------------------------------------------
# Authentication (JWT)
# Generate a strong secret: openssl rand -base64 48
# -----------------------------------------------------------------------
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------
# Password hashing
# -----------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=10

# -----------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW=1 minute

# -----------------------------------------------------------------------
# Logging
# LOG_LEVEL: fatal | error | warn | info | debug | trace
# LOG_PRETTY: true for human-readable output (dev), false for JSON (prod)
# -----------------------------------------------------------------------
LOG_LEVEL=debug
LOG_PRETTY=true

# -----------------------------------------------------------------------
# File Storage (MinIO / AWS S3)
# For local dev, MinIO runs via docker compose on port 9000
# -----------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=promanage-dev
S3_REGION=us-east-1

# -----------------------------------------------------------------------
# Observability — Sentry (optional)
# Leave blank or omit to disable Sentry entirely.
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# Install SDK first: pnpm --filter @promanage/api add @sentry/node
# -----------------------------------------------------------------------
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
