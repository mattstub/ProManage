generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ORGANIZATION (Tenant)
// ===========================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  email     String?
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  roles          Role[]
  projects       Project[]
  tasks          Task[]
  procedures     Procedure[]
  calendarEvents CalendarEvent[]
  notifications  Notification[]
  conversations  Conversation[]
  announcements  Announcement[]
  channels       Channel[]
  contacts       Contact[]
  licenses       License[]
  projectScopes  ProjectScope[]
  safetyDocuments SafetyDocument[]
  sdsEntries      SdsEntry[]
  toolboxTalks    ToolboxTalk[]
  safetyForms     SafetyForm[]
  incidentReports IncidentReport[]

  drawingDisciplines    DrawingDiscipline[]
  drawingSets           DrawingSet[]
  drawingSheets         DrawingSheet[]
  drawingRevisions      DrawingRevision[]
  specificationSections SpecificationSection[]
  specificationRevisions SpecificationRevision[]

  @@map("organizations")
}

// ===========================================
// USER
// ===========================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  userRoles     UserRole[]
  refreshTokens RefreshToken[]

  tasksAssigned          Task[]          @relation("TaskAssignee")
  tasksCreated           Task[]          @relation("TaskCreator")
  proceduresCreated      Procedure[]     @relation("ProcedureCreator")
  calendarEventsCreated  CalendarEvent[] @relation("CalendarEventCreator")
  notifications          Notification[]
  conversationsAsA       Conversation[]  @relation("ConversationParticipantA")
  conversationsAsB       Conversation[]  @relation("ConversationParticipantB")
  directMessagesSent     DirectMessage[] @relation("DirectMessageSender")
  announcementsAuthored  Announcement[]  @relation("AnnouncementAuthor")
  announcementReads      AnnouncementRead[]
  channelMemberships     ChannelMember[]
  chatMessagesSent       ChatMessage[]   @relation("ChatMessageSender")
  contactsCreated        Contact[]       @relation("ContactCreator")
  licensesHeld           License[]       @relation("LicenseHolder")
  licensesCreated        License[]       @relation("LicenseCreator")
  licenseDocumentsUploaded LicenseDocument[] @relation("LicenseDocumentUploader")
  licenseRemindersAsNotify      LicenseReminder[] @relation("LicenseReminderNotifyUser")
  licenseRemindersAsSupervisor  LicenseReminder[] @relation("LicenseReminderSupervisor")

  safetyDocumentsUploaded  SafetyDocument[]      @relation("SafetyDocumentUploader")
  sdsEntriesCreated        SdsEntry[]            @relation("SdsEntryCreator")
  toolboxTalksCreated      ToolboxTalk[]         @relation("ToolboxTalkCreator")
  toolboxTalksConducted    ToolboxTalk[]         @relation("ToolboxTalkConductor")
  toolboxTalkAttendances   ToolboxTalkAttendee[] @relation("ToolboxTalkAttendeeUser")
  safetyFormsCreated       SafetyForm[]          @relation("SafetyFormCreator")
  incidentReportsReported  IncidentReport[]      @relation("IncidentReporter")

  drawingSetsCreated          DrawingSet[]          @relation("DrawingSetCreator")
  drawingRevisionsUploaded    DrawingRevision[]     @relation("DrawingRevisionUploader")
  specSectionsCreated         SpecificationSection[] @relation("SpecSectionCreator")
  specRevisionsUploaded       SpecificationRevision[] @relation("SpecRevisionUploader")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ===========================================
// RBAC: Roles, Permissions, Assignments
// ===========================================

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String @map("role_id")

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ===========================================
// AUTHENTICATION
// ===========================================

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ===========================================
// PROJECT (Phase 4.1)
// ===========================================

model Project {
  id                 String    @id @default(cuid())
  name               String
  number             String
  type               String    @default("Commercial")
  status             String    @default("Bidding")
  description        String?
  address            String?
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  // Extended metadata (Phase 4.1)
  ownerName          String?   @map("owner_name")
  ownerPhone         String?   @map("owner_phone")
  ownerEmail         String?   @map("owner_email")
  architectName      String?   @map("architect_name")
  contractorLicense  String?   @map("contractor_license")
  permitNumber       String?   @map("permit_number")
  budget             Decimal?  @db.Decimal(15, 2)
  squareFootage      Int?      @map("square_footage")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  tasks           Task[]
  procedures      Procedure[]
  calendarEvents  CalendarEvent[]
  channels        Channel[]
  contactProjects ContactProject[]
  toolboxTalks    ToolboxTalk[]
  incidentReports IncidentReport[]
  scopes          ProjectScope[]
  settings        ProjectSettings?

  drawingSets           DrawingSet[]
  drawingSheets         DrawingSheet[]
  specificationSections SpecificationSection[]

  @@unique([number, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@map("projects")
}

model ProjectScope {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("Active") // Active | Completed | OnHold | Cancelled
  sequence    Int       @default(0)
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Decimal?  @db.Decimal(15, 2)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String       @map("project_id")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  @@index([projectId])
  @@index([organizationId])
  @@map("project_scopes")
}

model ProjectSettings {
  id                    String   @id @default(cuid())
  requireDailyReports   Boolean  @default(false) @map("require_daily_reports")
  requireTimeTracking   Boolean  @default(false) @map("require_time_tracking")
  enableSafetyModule    Boolean  @default(true)  @map("enable_safety_module")
  enableDocumentsModule Boolean  @default(false) @map("enable_documents_module")
  defaultView           String   @default("dashboard") @map("default_view")
  notifyOnIncident      Boolean  @default(true)  @map("notify_on_incident")
  notifyOnDailyReport   Boolean  @default(false) @map("notify_on_daily_report")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @unique @map("project_id")

  @@map("project_settings")
}

// ===========================================
// TASK (Phase 2.5)
// ===========================================

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("OPEN")
  priority    String    @default("MEDIUM")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @map("project_id")

  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId String? @map("assignee_id")

  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])
  creatorId String @map("creator_id")

  @@index([organizationId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

// ===========================================
// NOTIFICATION (Phase 2.2)
// ===========================================

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String   @default("INFO")
  read       Boolean  @default(false)
  entityId   String?  @map("entity_id")
  entityType String?  @map("entity_type")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  @@index([userId])
  @@index([organizationId])
  @@index([read])
  @@map("notifications")
}

// ===========================================
// CALENDAR EVENT (Phase 2.4)
// ===========================================

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  allDay      Boolean  @default(false) @map("all_day")
  eventType   String   @default("OTHER") @map("event_type")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @map("project_id")

  createdBy   User   @relation("CalendarEventCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  @@index([organizationId])
  @@index([projectId])
  @@index([createdById])
  @@index([startDate])
  @@index([endDate])
  @@map("calendar_events")
}

// ===========================================
// PROCEDURE (Phase 2.6)
// ===========================================

model Procedure {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("General")
  status    String   @default("DRAFT")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @map("project_id")

  createdBy   User   @relation("ProcedureCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  @@index([organizationId])
  @@index([projectId])
  @@index([createdById])
  @@index([status])
  @@map("procedures")
}

// ===========================================
// MESSAGING (Phase 2.3)
// ===========================================

// Canonical ordering: participantAId < participantBId (lexicographic)
// enforced in service layer to guarantee @@unique works correctly
model Conversation {
  id             String   @id @default(cuid())
  lastMessageAt  DateTime @default(now()) @map("last_message_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  participantA   User   @relation("ConversationParticipantA", fields: [participantAId], references: [id])
  participantAId String @map("participant_a_id")

  participantB   User   @relation("ConversationParticipantB", fields: [participantBId], references: [id])
  participantBId String @map("participant_b_id")

  messages DirectMessage[]

  @@unique([organizationId, participantAId, participantBId])
  @@index([organizationId])
  @@index([participantAId])
  @@index([participantBId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model DirectMessage {
  id        String    @id @default(cuid())
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String       @map("conversation_id")

  sender   User   @relation("DirectMessageSender", fields: [senderId], references: [id])
  senderId String @map("sender_id")

  @@index([conversationId])
  @@index([senderId])
  @@index([readAt])
  @@map("direct_messages")
}

model Announcement {
  id          String    @id @default(cuid())
  subject     String
  body        String
  targetRole  String?   @map("target_role") // null = all users in org
  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  author   User   @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  authorId String @map("author_id")

  reads AnnouncementRead[]

  @@index([organizationId])
  @@index([authorId])
  @@index([sentAt])
  @@index([scheduledAt])
  @@map("announcements")
}

model AnnouncementRead {
  readAt DateTime @default(now()) @map("read_at")

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String       @map("announcement_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@id([announcementId, userId])
  @@index([userId])
  @@map("announcement_reads")
}

// ===========================================
// CHANNELS (Phase 2.3B)
// ===========================================

model Channel {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  isPrivate   Boolean  @default(false) @map("is_private")
  projectId   String?  @map("project_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project     Project?            @relation(fields: [projectId], references: [id])
  members     ChannelMember[]
  permissions ChannelPermission[]
  messages    ChatMessage[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([projectId])
  @@map("channels")
}

model ChannelPermission {
  id        String  @id @default(cuid())
  roleName  String  @map("role_name")
  canRead   Boolean @default(true)  @map("can_read")
  canWrite  Boolean @default(true)  @map("can_write")
  canManage Boolean @default(false) @map("can_manage")

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String  @map("channel_id")

  @@unique([channelId, roleName])
  @@index([channelId])
  @@map("channel_permissions")
}

model ChannelMember {
  joinedAt DateTime @default(now()) @map("joined_at")

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String  @map("channel_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@id([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@map("channel_members")
}

model ChatMessage {
  id        String    @id @default(cuid())
  body      String
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String  @map("channel_id")

  sender   User   @relation("ChatMessageSender", fields: [senderId], references: [id])
  senderId String @map("sender_id")

  parent   ChatMessage?  @relation("MessageThread", fields: [parentId], references: [id])
  parentId String?       @map("parent_id")
  replies  ChatMessage[] @relation("MessageThread")

  attachments MessageAttachment[]

  @@index([channelId])
  @@index([senderId])
  @@index([parentId])
  @@index([createdAt])
  @@map("chat_messages")
}

model MessageAttachment {
  id         String   @id @default(cuid())
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  storageKey String   @map("storage_key")
  createdAt  DateTime @default(now()) @map("created_at")

  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String      @map("message_id")

  @@index([messageId])
  @@map("message_attachments")
}

// ===========================================
// CONTACTS (Phase 3.1)
// ===========================================

model Contact {
  id        String   @id @default(cuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  company   String?
  type      String   @default("CONTRACTOR")
  email     String?
  phone     String?
  mobile    String?
  title     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  createdBy   User   @relation("ContactCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  projectContacts ContactProject[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([type])
  @@index([createdById])
  @@map("contacts")
}

model ContactProject {
  assignedAt DateTime @default(now()) @map("assigned_at")
  role       String?  // project-specific role label (e.g. "Site Superintendent")

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String  @map("contact_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")

  @@id([contactId, projectId])
  @@index([contactId])
  @@index([projectId])
  @@map("contact_projects")
}

// ===========================================
// LICENSING (Phase 3.2)
// ===========================================

model License {
  id             String    @id @default(cuid())
  name           String
  licenseNumber  String?   @map("license_number")
  authority      String?
  licenseType    String?   @map("license_type")
  holderType     String    @default("ORGANIZATION") @map("holder_type") // ORGANIZATION | USER
  startDate      DateTime? @map("start_date")
  expirationDate DateTime? @map("expiration_date")
  renewalDate    DateTime? @map("renewal_date")
  status         String    @default("ACTIVE") // ACTIVE | EXPIRED | PENDING | SUSPENDED | REVOKED
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  // nullable — populated when holderType is USER
  user   User?   @relation("LicenseHolder", fields: [userId], references: [id])
  userId String? @map("user_id")

  createdBy   User   @relation("LicenseCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  documents LicenseDocument[]
  reminders LicenseReminder[]

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([expirationDate])
  @@map("licenses")
}

model LicenseDocument {
  id          String   @id @default(cuid())
  fileName    String   @map("file_name")
  fileKey     String   @map("file_key")  // MinIO object key
  fileUrl     String   @map("file_url")
  fileSize    Int      @map("file_size") // bytes
  mimeType    String   @map("mime_type")
  documentTag String?  @map("document_tag") // e.g. "2024 Application", "Current License"
  createdAt   DateTime @default(now()) @map("created_at")

  license   License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  licenseId String  @map("license_id")

  uploadedBy   User   @relation("LicenseDocumentUploader", fields: [uploadedById], references: [id])
  uploadedById String @map("uploaded_by_id")

  @@index([licenseId])
  @@map("license_documents")
}

model LicenseReminder {
  id                   String    @id @default(cuid())
  daysBeforeExpiration Int       @map("days_before_expiration")
  // <=7 days → fires daily; >7 days → fires once per expiration cycle
  notifyUserId         String    @map("notify_user_id")
  notifySupervisorId   String?   @map("notify_supervisor_id")
  isActive             Boolean   @default(true) @map("is_active")
  lastNotifiedAt       DateTime? @map("last_notified_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  license   License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  licenseId String  @map("license_id")

  notifyUser       User  @relation("LicenseReminderNotifyUser", fields: [notifyUserId], references: [id])
  notifySupervisor User? @relation("LicenseReminderSupervisor", fields: [notifySupervisorId], references: [id])

  @@index([licenseId])
  @@map("license_reminders")
}

// ===========================================
// SAFETY (Phase 3.3)
// ===========================================

model SafetyDocument {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("POLICY") // POLICY | PROCEDURE | EMERGENCY_PLAN | TRAINING | COMPLIANCE | OTHER
  fileName    String   @map("file_name")
  fileKey     String   @map("file_key")  // MinIO object key
  fileSize    Int      @map("file_size") // bytes
  mimeType    String   @map("mime_type")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  uploadedBy   User   @relation("SafetyDocumentUploader", fields: [uploadedById], references: [id])
  uploadedById String @map("uploaded_by_id")

  @@index([organizationId])
  @@index([category])
  @@index([uploadedById])
  @@map("safety_documents")
}

model SdsEntry {
  id           String    @id @default(cuid())
  productName  String    @map("product_name")
  manufacturer String?
  chemicalName String?   @map("chemical_name")
  sdsFileKey   String?   @map("sds_file_key")   // MinIO object key (optional)
  sdsFileName  String?   @map("sds_file_name")
  reviewDate   DateTime? @map("review_date")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  createdBy   User   @relation("SdsEntryCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  @@index([organizationId])
  @@index([createdById])
  @@map("sds_entries")
}

model ToolboxTalk {
  id            String    @id @default(cuid())
  title         String
  content       String?
  scheduledDate DateTime? @map("scheduled_date")
  conductedDate DateTime? @map("conducted_date")
  status        String    @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @map("project_id")

  conductedBy   User?   @relation("ToolboxTalkConductor", fields: [conductedById], references: [id])
  conductedById String? @map("conducted_by_id")

  createdBy   User   @relation("ToolboxTalkCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  attendees ToolboxTalkAttendee[]

  @@index([organizationId])
  @@index([projectId])
  @@index([conductedById])
  @@index([createdById])
  @@index([status])
  @@map("toolbox_talks")
}

model ToolboxTalkAttendee {
  id        String    @id @default(cuid())
  name      String    // display name (for manual / non-system attendees)
  signedAt  DateTime? @map("signed_at")
  createdAt DateTime  @default(now()) @map("created_at")

  talk   ToolboxTalk @relation(fields: [talkId], references: [id], onDelete: Cascade)
  talkId String      @map("talk_id")

  user   User?   @relation("ToolboxTalkAttendeeUser", fields: [userId], references: [id])
  userId String? @map("user_id")

  @@index([talkId])
  @@index([userId])
  @@map("toolbox_talk_attendees")
}

model SafetyForm {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("INSPECTION") // INSPECTION | JSA | HAZARD_ASSESSMENT | PERMIT | TAILGATE | OTHER
  content     String   @default("") // form template body (markdown / instructions)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  createdBy   User   @relation("SafetyFormCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  @@index([organizationId])
  @@index([category])
  @@index([createdById])
  @@index([isActive])
  @@map("safety_forms")
}

model IncidentReport {
  id               String   @id @default(cuid())
  title            String
  incidentType     String   @map("incident_type") // NEAR_MISS | FIRST_AID | RECORDABLE | PROPERTY_DAMAGE | FATALITY | ENVIRONMENTAL
  incidentDate     DateTime @map("incident_date")
  location         String?
  description      String
  correctiveAction String?  @map("corrective_action")
  status           String   @default("OPEN") // OPEN | UNDER_REVIEW | CLOSED
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @map("project_id")

  reportedBy   User   @relation("IncidentReporter", fields: [reportedById], references: [id])
  reportedById String @map("reported_by_id")

  @@index([organizationId])
  @@index([projectId])
  @@index([reportedById])
  @@index([status])
  @@index([incidentDate])
  @@map("incident_reports")
}

// ===========================================
// PHASE 4.2 — CONSTRUCTION DOCUMENTS
// ===========================================

model DrawingDiscipline {
  id           String   @id @default(cuid())
  name         String
  abbreviation String?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  sheets DrawingSheet[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("drawing_disciplines")
}

model DrawingSet {
  id          String    @id @default(cuid())
  name        String
  phase       String    @default("CONSTRUCTION_DOCUMENTS") // DESIGN_DEVELOPMENT | BIDDING_DOCUMENTS | CONSTRUCTION_DOCUMENTS
  issueDate   DateTime? @map("issue_date")
  issuedBy    String?   @map("issued_by")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")

  createdBy   User   @relation("DrawingSetCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  revisions DrawingRevision[]

  @@index([organizationId])
  @@index([projectId])
  @@index([createdById])
  @@map("drawing_sets")
}

model DrawingSheet {
  id          String   @id @default(cuid())
  sheetNumber String   @map("sheet_number")
  title       String
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")

  discipline   DrawingDiscipline? @relation(fields: [disciplineId], references: [id])
  disciplineId String?            @map("discipline_id")

  revisions DrawingRevision[]

  @@unique([sheetNumber, projectId])
  @@index([organizationId])
  @@index([projectId])
  @@index([disciplineId])
  @@map("drawing_sheets")
}

model DrawingRevision {
  id             String    @id @default(cuid())
  revisionNumber String    @map("revision_number") // freeform: "0", "1", "PR1", "A", "ASI-1"
  revisionDate   DateTime  @map("revision_date")
  description    String?
  fileKey        String?   @map("file_key")
  fileName       String?   @map("file_name")
  fileSize       Int?      @map("file_size")
  mimeType       String?   @map("mime_type")
  isCurrent      Boolean   @default(false) @map("is_current")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  sheet   DrawingSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  sheetId String       @map("sheet_id")

  drawingSet   DrawingSet? @relation(fields: [drawingSetId], references: [id])
  drawingSetId String?     @map("drawing_set_id")

  uploadedBy   User   @relation("DrawingRevisionUploader", fields: [uploadedById], references: [id])
  uploadedById String @map("uploaded_by_id")

  @@index([organizationId])
  @@index([sheetId])
  @@index([drawingSetId])
  @@index([uploadedById])
  @@map("drawing_revisions")
}

model SpecificationSection {
  id            String   @id @default(cuid())
  sectionNumber String   @map("section_number") // freeform: "03 00 00", "03300", "DIVISION 3"
  title         String
  description   String?
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")

  createdBy   User   @relation("SpecSectionCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  revisions SpecificationRevision[]

  @@unique([sectionNumber, projectId])
  @@index([organizationId])
  @@index([projectId])
  @@index([createdById])
  @@map("specification_sections")
}

model SpecificationRevision {
  id             String   @id @default(cuid())
  revisionNumber Int      @default(1) @map("revision_number") // auto-incremented per section
  revisionDate   DateTime @map("revision_date")
  description    String?
  isAmendment    Boolean  @default(false) @map("is_amendment") // true = conformed amendment
  fileKey        String?  @map("file_key")
  fileName       String?  @map("file_name")
  fileSize       Int?     @map("file_size")
  mimeType       String?  @map("mime_type")
  isCurrent      Boolean  @default(false) @map("is_current")
  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  section   SpecificationSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String               @map("section_id")

  uploadedBy   User   @relation("SpecRevisionUploader", fields: [uploadedById], references: [id])
  uploadedById String @map("uploaded_by_id")

  @@index([organizationId])
  @@index([sectionId])
  @@index([uploadedById])
  @@map("specification_revisions")
}
