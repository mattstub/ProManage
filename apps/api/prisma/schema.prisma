// ===========================================
// PHASE 6.1 — CONTRACTS
// ===========================================

enum ContractType {
  LUMP_SUM
  COST_PLUS
  TIME_AND_MATERIALS
  UNIT_PRICE
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  COMPLETED
  TERMINATED
  ON_HOLD
}

enum ContractDocumentType {
  INSURANCE
  BONDING
  SALES_TAX_REQUEST
  SALES_TAX_EXEMPTION
  OTHER
}

enum ContractDocumentStatus {
  REQUESTED
  RECEIVED
  EXPIRED
  WAIVED
}

model Contract {
  id                    String         @id @default(cuid())
  contractNumber        String         @map("contract_number")
  type                  ContractType   @map("type")
  status                ContractStatus @default(DRAFT) @map("status")
  amount                Decimal        @map("amount") @db.Decimal(15, 2)
  customerProjectNumber String?        @map("customer_project_number")
  retentionRate         Decimal?       @map("retention_rate") @db.Decimal(5, 2) // percentage e.g. 10.00
  wageRequirements      String?        @map("wage_requirements")                 // prevailing wage, Davis-Bacon, etc.
  taxStatus             String?        @map("tax_status")                        // taxable | exempt | partial
  liquidatedDamages     Boolean        @default(false) @map("liquidated_damages")
  liquidatedDamagesRate Decimal?       @map("liquidated_damages_rate") @db.Decimal(12, 2) // per-day rate
  bonded                Boolean        @default(false) @map("bonded")
  billingDate           DateTime?      @map("billing_date")
  startDate             DateTime?      @map("start_date")
  executedDate          DateTime?      @map("executed_date")
  description           String?
  notes                 String?
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")

  proposal   Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  proposalId String?   @map("proposal_id")

  createdBy   User   @relation("ContractCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  documents ContractDocument[]

  @@unique([organizationId, contractNumber])
  @@index([organizationId])
  @@index([projectId])
  @@index([proposalId])
  @@index([status])
  @@map("contracts")
}

model ContractDocument {
  id         String                 @id @default(cuid())
  type       ContractDocumentType   @map("type")
  name       String
  status     ContractDocumentStatus @default(REQUESTED) @map("status")
  fileKey    String?                @map("file_key")
  fileName   String?                @map("file_name")
  fileSize   Int?                   @map("file_size")
  mimeType   String?                @map("mime_type")
  notes      String?
  expiresAt  DateTime?              @map("expires_at")
  receivedAt DateTime?              @map("received_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String   @map("contract_id")

  uploadedBy   User?   @relation("ContractDocumentUploader", fields: [uploadedById], references: [id])
  uploadedById String? @map("uploaded_by_id")

  @@index([contractId])
  @@index([uploadedById])
  @@map("contract_documents")
}

// ===========================================
// PHASE 6.2 — SUBMITTALS
// ===========================================

enum SubmittalType {
  SHOP_DRAWINGS
  PRODUCT_DATA
  SAMPLES
  MOCKUPS
  CALCULATIONS
  VENDOR_INFO
  WARRANTIES
  MANUALS
  AS_BUILTS
}

enum SubmittalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  APPROVED_AS_NOTED
  REVISE_RESUBMIT
  REJECTED
  VOID
}

model Submittal {
  id               String          @id @default(cuid())
  submittalNumber  String          @map("submittal_number")
  specSection      String?         @map("spec_section")  // e.g. "03-300"
  title            String
  description      String?
  type             SubmittalType   @map("type")
  status           SubmittalStatus @default(DRAFT) @map("status")
  revision         Int             @default(1)
  submittedDate    DateTime?       @map("submitted_date")
  requiredByDate   DateTime?       @map("required_by_date")
  returnedDate     DateTime?       @map("returned_date")
  ballInCourt      String?         @map("ball_in_court") // "Architect" | "GC" | "Subcontractor" | etc.
  approver         String?                               // architect/engineer name
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")

  createdBy   User   @relation("SubmittalCreator", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  documents SubmittalDocument[]

  @@unique([organizationId, submittalNumber])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@map("submittals")
}

model SubmittalDocument {
  id        String   @id @default(cuid())
  name      String
  fileKey   String?  @map("file_key")
  fileName  String?  @map("file_name")
  fileSize  Int?     @map("file_size")
  mimeType  String?  @map("mime_type")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submittal   Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  submittalId String    @map("submittal_id")

  uploadedBy   User?   @relation("SubmittalDocumentUploader", fields: [uploadedById], references: [id])
  uploadedById String? @map("uploaded_by_id")

  @@index([submittalId])
  @@index([uploadedById])
  @@map("submittal_documents")
}
