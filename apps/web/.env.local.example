# Copy this file to .env.local and fill in the values.
# cp apps/web/.env.local.example apps/web/.env.local

# -----------------------------------------------------------------------
# API
# URL of the ProManage API server (no trailing slash)
# Must be set at Next.js *build* time — changing it requires a rebuild.
# -----------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------
# Observability — Sentry (optional)
# Leave blank or omit to disable Sentry entirely.
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# Install SDK first: pnpm --filter @promanage/web add @sentry/nextjs
# Then run: npx @sentry/wizard@latest -i nextjs
# -----------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
